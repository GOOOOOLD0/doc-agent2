# 默认使用阿里云百炼千问。API Key 只能保存在本机 .env，不得提交。
LANDING_RIGHTS_PROVIDER=qwen
DASHSCOPE_API_KEY=

# 旧版公共域名仍可使用；也可替换为百炼业务空间专属 base URL。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 主模型推荐 qwen3.6-flash；超低成本批量摘要可改为 qwen3.5-flash。
LANDING_RIGHTS_MODEL=qwen3.6-flash
LANDING_RIGHTS_REASONING_EFFORT=medium

# 如需切回 OpenAI，将 PROVIDER 改为 openai 并填写以下配置。
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
